                <!--script for nested header start-->
        <style>
            @media (min-width: 992px) {
                .menu ul.sub_menu {
                    position: relative !important;
                    left: 0;
                    filter: unset;
                    background-color: #0000001c !important;
                    margin-left: 5px;
                    border-left: none;
                }
                .menu li:hover > ul.sub_menu {
                    display: none;
                }
                .menu li > ul.sub_menu.open {
                    display: block;
                }
                .menu ul.sub_menu > li:hover>a {
                    background-color: #0000001c;
                }
                .menu ul > li>a > img {
                    transition: all ease-in-out 0.2s;
                }
                .menu ul > li>a.open > img {
                    transform: rotate(90deg);
                }
            }
        </style>
        <script>
            if (window.innerWidth < 992) {
               document.addEventListener("DOMContentLoaded", function() {
                   var closeMenuLinks = document.getElementsByClassName("back-menu-second");
                   var mainMenuLinks = document.querySelectorAll(".main_menu > a > img");


                   for (var i = 0; i < closeMenuLinks.length; i++) {
                   closeMenuLinks[i].addEventListener("click", function(e) {
                       e.preventDefault();
                       var parentSubMenu = this.closest(".second_menu");


                       // Remove the open class from the parent sub-menu
                       parentSubMenu.classList.remove("open");
                   });
                   }


                   for (var j = 0; j < mainMenuLinks.length; j++) {
                   mainMenuLinks[j].addEventListener("click", function(e) {
                       e.preventDefault();
                       var nestedMenu = this.parentNode.nextElementSibling;


                       // Toggle the open class for the nested menu
                       nestedMenu.classList.toggle("open");
                   });
                   }
               });
            }
           </script>
        <script>
             if (window.innerWidth < 992) {
                 //for mobiles
                 document.addEventListener("DOMContentLoaded", function() {
                     var closeMenuLinks = document.getElementsByClassName("back-menu-sub");
                     var mainMenuLinks = document.querySelectorAll(".second_menu a > img");


                     for (var i = 0; i < closeMenuLinks.length; i++) {
                     closeMenuLinks[i].addEventListener("click", function(e) {
                         e.preventDefault();
                         var parentSubMenu = this.closest(".sub_menu");


                         // Remove the open class from the parent sub-menu
                         parentSubMenu.classList.remove("open");
                     });
                     }


                     for (var j = 0; j < mainMenuLinks.length; j++) {
                     mainMenuLinks[j].addEventListener("click", function(e) {
                         e.preventDefault();
                         var nestedMenu = this.parentNode.nextElementSibling;


                         // Toggle the open class for the nested menu
                         nestedMenu.classList.toggle("open");
                     });
                     }
                 });
             }
        </script>
